# Cache agresivo — assets inmutables
/js/*
  Cache-Control: public, max-age=31536000, immutable

/css/*
  Cache-Control: public, max-age=31536000, immutable

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/images/*
  Cache-Control: public, max-age=2592000

# HTML siempre fresco
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Service worker — siempre revalidar (navegadores lo limitan a 24h de todas formas)
/sw.js
  Cache-Control: no-store

# Datos de artículos — 1 día (contenido estático pero actualizable)
/articles.js
  Cache-Control: public, max-age=86400
