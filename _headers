# App pages y patient.html — nunca cachear (siempre versión fresca)
/app/*.html
  Cache-Control: no-store, no-cache, must-revalidate
  Pragma: no-cache

/patient.html
  Cache-Control: no-store, no-cache, must-revalidate
  Pragma: no-cache

/portafolio.html
  Cache-Control: no-store, no-cache, must-revalidate
  Pragma: no-cache

# Cache agresivo — assets inmutables
/js/*
  Cache-Control: public, max-age=31536000, immutable

/css/*
  Cache-Control: public, max-age=31536000, immutable

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/images/*
  Cache-Control: public, max-age=2592000

# HTML siempre fresco (aplica a .html files y clean URLs que Cloudflare Pages sirve)
/*.html
  Cache-Control: public, max-age=0, must-revalidate

