# ============================================================
# PRODIGY Digital Dentistry — Apache / Hosting Config
# Seguridad + Performance + SEO
# ============================================================

# ---- HTTPS Redirect (activar cuando tengas dominio) ----
# RewriteEngine On
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ---- Security Headers ----
<IfModule mod_headers.c>
    # Bloquea que tu página sea embebida en iframes de otros sitios
    Header always set X-Frame-Options "SAMEORIGIN"

    # Evita que el navegador adivine el tipo de archivo (MIME sniffing)
    Header always set X-Content-Type-Options "nosniff"

    # Activa protección XSS del navegador
    Header always set X-XSS-Protection "1; mode=block"

    # Controla qué información se envía al hacer referrer externo
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Permiso de cámara/micrófono/geolocalización (ninguno, más seguro)
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"

    # Content Security Policy — incluye todos los servicios externos del stack
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://www.paypal.com https://www.paypalobjects.com https://cdn.paddle.com https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data: https:; connect-src 'self' https://zgihrwqfyvgyapbwzkvw.supabase.co https://api.ipapi.co https://ipapi.co https://api.paypal.com https://www.paypal.com https://checkout.paddle.com https://api.paddle.com https://sandbox.wompi.co https://production.wompi.co https://graph.facebook.com https://wa.me; frame-src https://www.paypal.com https://checkout.paddle.com; frame-ancestors 'none';"

    # HSTS: fuerza HTTPS por 1 año (activar solo cuando tengas SSL)
    # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# ---- Compresión Gzip ----
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ---- Cache de Activos Estáticos ----
<IfModule mod_expires.c>
    ExpiresActive On

    # Imágenes: 30 días
    ExpiresByType image/jpg "access plus 30 days"
    ExpiresByType image/jpeg "access plus 30 days"
    ExpiresByType image/png "access plus 30 days"
    ExpiresByType image/svg+xml "access plus 30 days"
    ExpiresByType image/webp "access plus 30 days"

    # CSS y JS minificados: 7 días
    ExpiresByType text/css "access plus 7 days"
    ExpiresByType application/javascript "access plus 7 days"

    # Fuentes: 1 año
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
</IfModule>

# ---- Bloquear archivos de configuración y desarrollo ----
<FilesMatch "\.(json|md|htaccess|gitignore|env|sql|bat|zip)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# ---- Bloquear archivos con nombres sensibles específicos ----
<FilesMatch "^(admin-panel|agregar-caso|ESQUEMA_SUPABASE|PRODIGY_SCHEMA_SUPABASE|minify|package|package-lock)">
    Order allow,deny
    Deny from all
</FilesMatch>

# ---- Bloquear carpetas internas ----
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Bloquear carpeta temporal/
    RewriteRule ^temporal/ - [F,L]

    # Bloquear carpeta .claude/
    RewriteRule ^\.claude/ - [F,L]

    # Bloquear acceso directo al panel admin (solo local)
    RewriteRule ^admin-panel\.html$ - [F,L]

    # Bloquear archivos backup y copias
    RewriteRule ^.*(-copia|-BACKUP|BACKUP|copia).*\.html$ - [F,L]
</IfModule>

# ---- Bloquear imágenes con datos personales/QR de pago ----
<FilesMatch "^qr ">
    Order allow,deny
    Deny from all
</FilesMatch>

# ---- Ocultar versión de Apache ----
ServerSignature Off
