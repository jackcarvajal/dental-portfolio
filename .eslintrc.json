{
  "env": {
    "browser": true,
    "es2020": true
  },
  "parserOptions": {
    "ecmaVersion": 2020
  },
  "rules": {
    "no-undef": "error",
    "no-unreachable": "error",
    "no-dupe-keys": "error",
    "no-duplicate-case": "error",
    "no-extra-semi": "warn",
    "no-unexpected-multiline": "error"
  },
  "globals": {
    "STATE":            "readonly",
    "CONFIG":           "readonly",
    "calcularTotal":    "readonly",
    "getSupabase":      "readonly",
    "deepFreeze":       "readonly",
    "SUB_MATERIALES":   "writable",
    "SUB_MATERIALES_FALLBACK": "readonly",
    "inicializarCatalogo": "readonly",
    "showProdigyAlert": "readonly",
    "closeModal":       "readonly",
    "showPaymentModal": "readonly"
  }
}
